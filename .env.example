PORT=8787
NODE_ENV=development
OPENAI_API_KEY=<SECRET>
OPENAI_ANALYSIS_MODEL=gpt-4.1-mini
OPENAI_FINAL_REVIEW_MODEL=gpt-4.1
OPENAI_TRANSCRIPT_CLEANUP_MODEL=gpt-4.1-mini
ENABLE_AI_TRANSCRIPT_CLEANUP=false
AI_MIN_ANALYSIS_INTERVAL_MS=3500
AI_MIN_WORDS_FOR_ANALYSIS=6
AI_REQUEST_TIMEOUT_MS=2800
AI_TARGET_LATENCY_MS=3000
AI_CONTEXT_WINDOW_SEGMENTS=6
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=appointment-audio
COMPLIANCE_LOG_RETENTION_DAYS=365
CODEBOOK_STALE_DAYS=90
REQUEST_BODY_LIMIT_MB=2
CORS_ALLOWED_ORIGINS=
TRUST_PROXY=false
REQUIRE_API_KEY=false
INTERNAL_API_KEY=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
